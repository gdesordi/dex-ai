{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Dex Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extension/dex"
      ],
      "outFiles": [
        "${workspaceFolder}/extension/dex/out/**/*.js"
      ],
      "preLaunchTask": "build: dex"
    }
  ]
}
